# ─── Database (Supabase Postgres) ───────────────────────────────────────────
# Prisma talks to a normal PostgreSQL URL. Supabase is that database.
#
# How to get the string:
#   1. Open https://supabase.com/dashboard → your project
#   2. Project Settings → Database
#   3. Under "Connection string" choose URI
#   4. Copy the URI and paste it as DATABASE_URL below (replace [YOUR-PASSWORD])
#
# Tips:
#   - Use the Session or Transaction POOLER URI from the dashboard on most PCs.
#     Direct host db.<ref>.supabase.co is often IPv6-only → Prisma P1001 if you
#     only have IPv4 (common on Windows home networks).
#   - Session pooler: good for migrate / long-lived Node servers (port 5432 on pooler host).
#   - Transaction pooler (port 6543): good for serverless (Netlify functions).
#   - Pooler username is usually postgres.YOUR_PROJECT_REF (not just postgres).
#   - URL-encode special password chars (! → %21). Append ?sslmode=require if needed.
#
# Example (pooler — preferred):
# DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require"
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-long-random-string"
# Public site origin (local, Netlify, or custom domain)
AUTH_URL="http://localhost:3000"

# Admin seed (credentials login)
# Login username is fixed as "admin" for now (see src/lib/auth.ts)
ADMIN_EMAIL="admin@mcneelyfamilypoodles.com"
ADMIN_PASSWORD="password"
ADMIN_NAME="Site Admin"

# Customer OAuth (Google / Facebook) — required for /portal sign-in
# Google Cloud Console → OAuth client → Authorized redirect URIs:
#   {AUTH_URL}/api/auth/callback/google
# Meta for Developers → Facebook Login → Valid OAuth Redirect URIs:
#   {AUTH_URL}/api/auth/callback/facebook
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_FACEBOOK_ID=""
AUTH_FACEBOOK_SECRET=""

# Cloudflare Turnstile (free captcha for email signup, if enabled)
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Deposit handles shown to customers (also editable via SiteSetting)
VENMO_HANDLE=""
ZELLE_CONTACT=""
PAYPAL_ME_URL=""

# ImgBB — free image hosting for public photos (bypasses Netlify static size limits).
# Get a key: https://api.imgbb.com/ → "Get API key"
# Upload returns a public https URL stored in the DB; the site only hotlinks that URL.
IMGBB_API_KEY=""
