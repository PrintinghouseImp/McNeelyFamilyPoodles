# PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/mcneely_family_poodles"

# Auth.js — openssl rand -base64 32
AUTH_SECRET="replace-with-long-random-string"
AUTH_URL="http://localhost:3000"

# Admin seed (credentials login)
# Login username is fixed as "admin" for now (see src/lib/auth.ts)
ADMIN_EMAIL="admin@mcneelyfamilypoodles.com"
ADMIN_PASSWORD="password"
ADMIN_NAME="Site Admin"

# Customer OAuth (Google / Facebook) — required for /portal sign-in
# Google Cloud Console → OAuth client → Authorized redirect URIs:
#   {AUTH_URL}/api/auth/callback/google
# Meta for Developers → Facebook Login → Valid OAuth Redirect URIs:
#   {AUTH_URL}/api/auth/callback/facebook
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_FACEBOOK_ID=""
AUTH_FACEBOOK_SECRET=""

# Cloudflare Turnstile (free captcha for email signup, if enabled)
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Deposit handles shown to customers (also editable via SiteSetting)
VENMO_HANDLE=""
ZELLE_CONTACT=""
PAYPAL_ME_URL=""
