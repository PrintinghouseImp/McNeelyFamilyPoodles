# ─── Database (Supabase Postgres) ───────────────────────────────────────────
# Prisma talks to a normal PostgreSQL URL. Supabase is that database.
#
# How to get the string:
#   1. Open https://supabase.com/dashboard → your project
#   2. Project Settings → Database
#   3. Under "Connection string" choose URI (prefer Session pooler on Windows)
#   4. Copy the URI and paste it as DATABASE_URL below (replace [YOUR-PASSWORD])
#
# Tips:
#   - Direct host db.<ref>.supabase.co is often IPv6-only → Prisma P1001 on IPv4-only PCs.
#   - Use Session pooler (port 5432 on pooler host) or Transaction pooler (6543) for serverless.
#   - Pooler username is usually postgres.YOUR_PROJECT_REF.
#   - URL-encode special password chars (! → %21).
#
# Example (pooler — preferred):
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-long-random-string"
# Public site origin (local, Netlify, or custom domain)
AUTH_URL="http://localhost:3000"

# Admin seed (credentials login)
# Login username is fixed as "admin" for now (see src/lib/auth.ts)
ADMIN_EMAIL="admin@mcneelyfamilypoodles.com"
ADMIN_PASSWORD="password"
ADMIN_NAME="Site Admin"

# Customer OAuth (Google / Facebook) — required for /portal sign-in
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_FACEBOOK_ID=""
AUTH_FACEBOOK_SECRET=""

# Cloudflare Turnstile (free captcha for email signup, if enabled)
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Deposit handles shown to customers (also editable via SiteSetting)
VENMO_HANDLE=""
ZELLE_CONTACT=""
PAYPAL_ME_URL=""

# ─── Cloudflare R2 (images + documents) ─────────────────────────────────────
# Public CDN / custom domain (already provisioned):
#   https://images.mcneelyfamilypoodles.com
#
# Setup checklist (Cloudflare dashboard):
#   1. R2 → Create bucket (e.g. mcneely-media)
#   2. Bucket → Settings → Public access / Custom Domains →
#        connect images.mcneelyfamilypoodles.com
#   3. R2 → Manage R2 API Tokens → Create API token
#        (Object Read & Write on that bucket)
#   4. Paste Account ID, Access Key ID, Secret Access Key, bucket name below
#
# When all R2_* vars are set, uploads go to R2 and URLs stored in the DB look like:
#   https://images.mcneelyfamilypoodles.com/uploads/puppy/<id>/<file>.webp
# When unset, uploads fall back to local public/uploads (dev only; not for Netlify).
#
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# Public base URL (no trailing slash). Override only if the custom domain changes.
R2_PUBLIC_URL="https://images.mcneelyfamilypoodles.com"
# Optional: defaults to https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_ENDPOINT=""
